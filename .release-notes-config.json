{
  "categories": [
    {
      "title": "## 🚀 Features",
      "labels": ["feat"]
    },
    {
      "title": "## 🐛 Fixes",
      "labels": ["fix"]
    },
    {
      "title": "## 📚 Documentation",
      "labels": ["docs"]
    },
    {
      "title": "## 🛠 Under the hood",
      "labels": []
    }
  ],
  "template": "${{CHANGELOG}}",
  "pr_template": "- [${{TITLE}}](https://github.com/punxaphil/custom-sonos-card/commit/${{MERGE_SHA}})",
  "empty_template": "- no changes",
  "label_extractor": [
    {
      "pattern": "^(\\w+)(?:\\(.*?\\))?: .+",
      "target": "$1",
      "method": "match"
    }
  ]
}
